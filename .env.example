OPENAI_API_KEY=your_openai_api_key_here

# Optional: use a different LLM provider
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Storage paths
CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads
DATABASE_URL=sqlite:///./data/legal_assistant.db

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# LLM model for analysis
LLM_MODEL=gpt-4o

# OCR
TESSERACT_CMD=/usr/bin/tesseract

# Server
HOST=0.0.0.0
PORT=8000

# CORS – comma-separated list of allowed origins.
# For production replace with your actual frontend URL(s).
# Using "*" disables credentials (cookies/Authorization headers) automatically.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
