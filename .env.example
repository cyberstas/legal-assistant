OPENAI_API_KEY=your_openai_api_key_here

# Optional: use a different LLM provider
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL connection (used for both structured data and pgvector embeddings)
# Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/legal_assistant

# Storage paths
UPLOAD_DIR=./data/uploads

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small

# LLM model for analysis
LLM_MODEL=gpt-4o

# OCR
TESSERACT_CMD=/usr/bin/tesseract

# Server
HOST=0.0.0.0
PORT=8000

# CORS – comma-separated list of allowed origins.
# For production replace with your actual frontend URL(s).
# Using "*" disables credentials (cookies/Authorization headers) automatically.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
